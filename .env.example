# Google OAuth (crear en Google Cloud Console)
GOOGLE_CLIENT_ID=tu_client_id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=tu_client_secret
# Local: http://localhost:3000/api/auth/callback
# Producción: https://video.basketouch.com/api/auth/callback
GOOGLE_REDIRECT_URI=

# Drive empresa + YouTube personal: Service Account para Drive
# Opción 1: GOOGLE_SERVICE_ACCOUNT_JSON (JSON en una línea)
# Opción 2: GOOGLE_SERVICE_ACCOUNT_JSON_BASE64 (para Vercel, más fiable)
#   Generar: echo -n '{"type":"service_account",...}' | base64
# Si está definido: Drive usa SA (empresa), OAuth solo para YouTube (personal).
# GOOGLE_SERVICE_ACCOUNT_JSON=
# GOOGLE_SERVICE_ACCOUNT_JSON_BASE64=

# Supabase
SUPABASE_URL=https://tu-proyecto.supabase.co
SUPABASE_SERVICE_KEY=tu_service_role_key

# Sesión (cualquier string seguro)
SESSION_SECRET=genera_un_secreto_aleatorio_largo

# Usuario admin (no se muestra en el login; en setup se crea con esta cuenta)
ADMIN_EMAIL=tu_email@ejemplo.com

# Carpeta de Drive donde están los vídeos (se abre al conectar)
DEFAULT_DRIVE_FOLDER_ID=

# YouTube: privacidad del vídeo (private | unlisted | public)
YOUTUBE_PRIVACY=private

# Postiz (opcional): publicar vía api.postiz.com con vídeo subido desde Drive
# POSTIZ_API_KEY=tu_api_key_desde_postiz_settings
# POSTIZ_API_BASE=https://api.postiz.com/public/v1
# Mapa: claves = valores de plataforma en la UI (youtube, linkedin, x, threads, tiktok, instagram, instagram_reel, skool)
# POSTIZ_INTEGRATION_MAP={"youtube":"uuid-canal-postiz","linkedin":"uuid"}
# TikTok vía Postiz (opcional): PUBLIC_TO_EVERYONE | MUTUAL_FOLLOW_FRIENDS | ...
# POSTIZ_TIKTOK_PRIVACY=PUBLIC_TO_EVERYONE

# Opcional
PORT=3000
